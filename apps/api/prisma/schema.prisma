// =============================================================================
// My Alquiler — prisma/schema.prisma (draft FINAL)
// PostgreSQL · multi-tenant por Inmobiliaria: TODO modelo de negocio lleva
// inmobiliariaId + relación. Catálogos GLOBALES sin tenant: Capacidad, Cupon,
// TramoPlan, TramoPlanConsorcios, MetaSemestre, CohortMes, FunnelStep,
// FuenteAdquisicion, BloqueadorObjetivo. CodigoOtp es infra de auth pre-tenant.
//
// DERIVADOS QUE NO SE PERSISTEN (los computa el API):
//   Contrato.estadoPagoActual / proximoVencimiento · Propietario.totalCobradoMes,
//   totalRecibirMes, propiedadesIds · dashboardMetrics / agenda / alertas / feed ·
//   SLA de reclamos (EN_TIEMPO/PROXIMO_VENCIMIENTO/VENCIDO) · estado suscripción
//   (AL_DIA/GRACIA/ATRASADO/PAUSADO) · MatchSugerido de resumen bancario ·
//   scoring inquilino · puntajeCargaBoletas · calendario / hitos · cargos a cobrar.
//
// Archivos: los dataUrl base64 del mock migran a object storage (campos *Url).
// Punitorios: lineales, recalculados al día (montoPunitorio de Liquidacion es
// snapshot informativo, la verdad la calcula el server con fechas LOCALES).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

