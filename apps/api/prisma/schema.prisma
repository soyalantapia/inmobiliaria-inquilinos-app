model Sociedad {
  id              String          @id @default(cuid())
  inmobiliariaId  String
  inmobiliaria    Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id])
  razonSocial     String
  nombreComercial String
  cuit            String
  condicionFiscal CondicionFiscal
  domicilioFiscal String
  email           String
  telefono        String
  cuentaCobranza  Json? // { banco, titular, cbu, alias, cuit }
  afip            Json? // { conectado, puntoVenta?, tipoComprobante? (incl. RECIBO_X), conectadoDesde? }
  esPrincipal     Boolean         @default(false) // exactamente 1 entre las activas
  activa          Boolean         @default(true) // baja lógica
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  propiedades Propiedad[]
  contratos   Contrato[]
  consorcios  Consorcio[]

  @@index([inmobiliariaId])
  // Índice ÚNICO PARCIAL "sociedades_principal_activa_key" sobre (inmobiliariaId)
  // WHERE esPrincipal=true AND activa=true (migración 20260621010000), creado a
  // mano porque Prisma no expresa índices parciales: una sola sociedad principal
  // activa por inmobiliaria. NO lo borres si migrate dev marca drift sobre sociedades.
  @@map("sociedades")
}

