// =============================================================================
// CORE — propietarios, propiedades, contratos, inquilinos, garantes
// =============================================================================

model Propietario {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  nombre         String
  apellido       String
  cuit           String
  email          String
  telefono       String
  cbuAlias       String? // null => alerta 'sin CBU no podemos rendir'
  comisionPct    Float        @default(8)
  notas          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // totalCobradoMes / totalRecibirMes / propiedadesIds: DERIVADOS, no persistir
  arca                     ArcaConfig?
  cuentaCobranza           CuentaCobranzaDirecta?
  participaciones          ParticipacionPropietario[]
  rendiciones              Rendicion[]
  contratosCobranzaDirecta Contrato[]                 @relation("CobranzaDirecta")

  @@index([inmobiliariaId])
  @@map("propietarios")
}

// 1:1 con Propietario. Si conectado=true, al conciliar un pago se emite
// factura/recibo automático con puntoVenta + tipoComprobante.
model ArcaConfig {
  id              String               @id @default(cuid())
  inmobiliariaId  String
  inmobiliaria    Inmobiliaria         @relation(fields: [inmobiliariaId], references: [id])
  propietarioId   String               @unique
  propietario     Propietario          @relation(fields: [propietarioId], references: [id])
  conectado       Boolean              @default(false)
  condicionFiscal CondicionFiscal?
  puntoVenta      String?
  tipoComprobante TipoComprobanteAfip?
  conectadoDesde  DateTime?
  updatedAt       DateTime             @updatedAt

  @@index([inmobiliariaId])
  @@map("arca_configs")
}

// Cuenta que ve el inquilino cuando el contrato es PROPIETARIO_DIRECTO.
model CuentaCobranzaDirecta {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  propietarioId  String       @unique
  propietario    Propietario  @relation(fields: [propietarioId], references: [id])
  banco          String
  titular        String
  cbu            String
  alias          String
  cuit           String
  updatedAt      DateTime     @updatedAt

  @@index([inmobiliariaId])
  @@map("cuentas_cobranza_directa")
}

model Propiedad {
  id               String          @id @default(cuid())
  inmobiliariaId   String
  inmobiliaria     Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id])
  direccion        String
  ciudad           String
  provincia        String
  tipo             TipoPropiedad
  ambientes        Int?
  m2               Float?
  fotoUrl          String?
  estado           EstadoPropiedad @default(EN_EDICION)
  contratoActualId String?         @unique // null si DISPONIBLE
  contratoActual   Contrato?       @relation("ContratoActual", fields: [contratoActualId], references: [id])
  sociedadId       String? // null => sociedad principal (fallback)
  sociedad         Sociedad?       @relation(fields: [sociedadId], references: [id])
  consorcioId      String? // FK que reemplaza el match heurístico por dirección
  consorcio        Consorcio?      @relation(fields: [consorcioId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  contratos         Contrato[]                 @relation("PropiedadContratos")
  participaciones   ParticipacionPropietario[]
  reclamos          Reclamo[]
  movimientosCaja   MovimientoCaja[]
  serviciosPublicos ServicioPublico[]
  invitados         InquilinoInvitado[]

  @@index([inmobiliariaId])
  @@index([sociedadId])
  @@index([consorcioId])
  @@map("propiedades")
}

// Cotitularidad: Σ porcentaje por propiedad = 100 ± 0.5 (valida el API).
// Sin filas explícitas => reparto igualitario.
model ParticipacionPropietario {
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  propiedadId    String
  propiedad      Propiedad    @relation(fields: [propiedadId], references: [id])
  propietarioId  String
  propietario    Propietario  @relation(fields: [propietarioId], references: [id])
  porcentaje     Float

  @@id([propiedadId, propietarioId])
  @@index([inmobiliariaId])
  @@index([propietarioId])
  @@map("participaciones_propietario")
}

model Contrato {
  id                        String         @id @default(cuid())
  inmobiliariaId            String
  inmobiliaria              Inmobiliaria   @relation(fields: [inmobiliariaId], references: [id])
  propiedadId               String
  propiedad                 Propiedad      @relation("PropiedadContratos", fields: [propiedadId], references: [id])
  sociedadId                String? // null => sociedad principal
  sociedad                  Sociedad?      @relation(fields: [sociedadId], references: [id])
  estado                    EstadoContrato @default(BORRADOR)
  monto                     Decimal        @db.Decimal(14, 2)
  moneda                    Moneda         @default(ARS)
  fechaInicio               DateTime
  fechaFin                  DateTime
  diaPago                   Int
  indiceAjuste              IndiceAjuste
  frecuenciaAjusteMeses     Int
  proximoAjuste             DateTime?
  tipoContrato              TipoContrato   @default(ALQUILER)
  montoExpensas             Decimal?       @db.Decimal(14, 2)
  cbuAlias                  String? // override del CBU del propietario para esta unidad
  titularCuenta             String?
  comisionInmobiliaria      Float?
  depositoGarantia          Decimal?       @db.Decimal(14, 2)
  // Estado/devolución del depósito. RETENIDO por defecto: mientras el contrato vive, la
  // inmo lo tiene en custodia. Al devolver/netear (rescisión) se registra monto y fecha.
  estadoDeposito            EstadoDeposito @default(RETENIDO)
  depositoDevueltoMonto     Decimal?       @db.Decimal(14, 2)
  depositoDevueltoAt        DateTime?
  // Motivo de la resolución del depósito (por qué se neteó/ejecutó): el caso "pelear
  // la garantía" (retener por daños/deuda). Se resuelve al egreso, no solo en rescisión.
  motivoDeposito            String?
  // Rescisión anticipada: fecha efectiva, motivo y penalidad en cánones (override del
  // default de la inmobiliaria). La penalidad se emite como CargoContrato al rescindir.
  fechaEfectivaRescision    DateTime?
  motivoRescision           String?
  penalidadRescisionMeses   Float?
  tasaPunitorioDiaria       Float? // LEGACY: % por día. Migrado a moraTipo/moraValor; queda por compat de lectura.
  // Esquema de mora del contrato (override del default de la inmobiliaria).
  // null => hereda (cascada en resolverEsquemaMora). moraValor se interpreta
  // según moraTipo: % diario, $ fijo por mes de atraso, o % mensual.
  moraTipo                  TipoMora?
  moraValor                 Float?
  modoCobranza              ModoCobranza   @default(INMOBILIARIA)
  cobraDirectoPropietarioId String?
  cobraDirectoPropietario   Propietario?   @relation("CobranzaDirecta", fields: [cobraDirectoPropietarioId], references: [id])

  // Workflow de carga/aprobación (rol CARGA => BORRADOR + pendienteAprobacion)
  cargadoPor          String?
  cargadoRol          Rol?
  cargadoAt           DateTime?
  pendienteAprobacion Boolean   @default(false)
  aprobadoPor         String?
  aprobadoAt          DateTime?

  // DERIVADOS (no persistidos): estadoPagoActual, proximoVencimiento
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propiedadActualDe   Propiedad?             @relation("ContratoActual")
  inquilinoTitular    Inquilino?
  garantes            Garante[]
  cargos              CargoContrato[]
  ajustes             AjusteAlquiler[]
  renovaciones        RenovacionContrato[]
  coInquilinos        CoInquilino[]
  liquidaciones       Liquidacion[]
  pagos               Pago[]
  comprobantes        Comprobante[]
  eventos             EventoContrato[]
  intencionRenovacion IntencionRenovacion?
  screenings          Screening[]
  drafts              ContratoDraft[]
  reclamos            Reclamo[]
  movimientosCaja     MovimientoCaja[]
  movimientosFeed     MovimientoFeed[]
  documentos          DocumentoContrato[]
  invitados           InquilinoInvitado[]
  boletas             BoletaServicio[]
  chatMensajes        ChatMensaje[]
  certificados        CertificadoInquilino[]
  cargosPagados       CargoPagado[]

  @@index([inmobiliariaId, estado])
  @@index([propiedadId])
  @@index([sociedadId])
  @@index([cobraDirectoPropietarioId])
  @@map("contratos")
}

// Draft de extracción IA (ContratoExtraido): cada campo {valor, confianza}.
model ContratoDraft {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String? // set al convertir el draft en Contrato
  contrato       Contrato?    @relation(fields: [contratoId], references: [id])
  datos          Json // { campo: { valor, confianza: 'alto'|'medio'|'bajo' } }
  creadoPor      String?
  createdAt      DateTime     @default(now())

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("contrato_drafts")
}

// Titular del contrato (mata la denormalización Contrato.inquilino).
// email = identidad de login OTP de la app inquilino.
model Inquilino {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  nombre         String
  apellido       String?
  email          String? // null hasta invitación; OTP requiere email
  telefono       String?
  cuit           String?
  dni            String?
  imageUrl       String? // avatar (foto de perfil en /uploads del tenant)
  esInvitado     Boolean      @default(false)
  contratoId     String?      @unique // titular 1:1
  contrato       Contrato?    @relation(fields: [contratoId], references: [id])
  // Persona a la que pertenece esta fila (una persona agrupa N contratos/inquilinos
  // dentro del tenant). Nullable: filas viejas quedan sin persona hasta el backfill.
  // El 1:1 con Contrato (contratoId @unique) NO cambia: cada contrato sigue teniendo
  // su fila Inquilino; personaId es la capa que las agrupa por encima.
  personaId      String?
  persona        Persona?     @relation(fields: [personaId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  acuses       AnuncioAcuse[]
  documentos   Documento[]
  certificados CertificadoInquilino[]
  codigosOtp   CodigoOtp[]

  @@unique([inmobiliariaId, email])
  @@index([inmobiliariaId])
  @@index([personaId])
  @@map("inquilinos")
}

// Persona = identidad reutilizable de un inquilino DENTRO de un tenant. Agrupa las N
// filas Inquilino (una por contrato) de la misma persona, para la ficha histórica del
// panel y para reusar un inquilino al armar un contrato nuevo. La identidad se ancla al
// DNI (único por tenant cuando no es null); sin DNI cada persona es distinta. NO se
// cascadea nada (Restrict por default, como todo el schema) → preservar el historial.
model Persona {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  dni            String?
  email          String?
  nombre         String
  apellido       String?
  telefono       String?
  cuit           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  inquilinos Inquilino[]

  // Único por (tenant, dni) SOLO cuando dni no es null (Postgres trata los NULL como
  // distintos → varias personas sin DNI conviven). Evita duplicar la misma persona
  // identificada por DNI y habilita el reuso; no fuerza DNI en quienes no lo tienen.
  @@unique([inmobiliariaId, dni])
  @@index([inmobiliariaId])
  @@map("personas")
}

model Garante {
  id               String       @id @default(cuid())
  inmobiliariaId   String
  inmobiliaria     Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  contratoId       String
  contrato         Contrato     @relation(fields: [contratoId], references: [id])
  tipo             TipoGarante
  // nombreProveedor = nombre del garante (persona) o de la aseguradora (caución).
  nombreProveedor  String
  dni              String? // DNI/CUIT del garante persona
  numeroPoliza     String?
  // Montos/vigencia son de una PÓLIZA (caución/digital): opcionales para un garante
  // persona (propietaria/sueldo), que no tiene cobertura ni vencimiento.
  montoCobertura   Decimal?     @db.Decimal(14, 2)
  vigenciaHasta    DateTime?
  contactoNombre   String? // contacto alternativo (broker de la póliza); un garante persona usa su propio nombre
  contactoTelefono String
  contactoEmail    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("garantes")
}

// Cargo one-off a un contrato (penalidad de rescisión, daños, ajuste puntual). Fuera del
// devengo mensual porque Liquidacion es @@unique([contratoId, periodo]) y no tiene concepto.
// Restrict por default (como todo el schema): no se cascadea al borrar contrato.
model CargoContrato {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato     @relation(fields: [contratoId], references: [id])
  tipo           TipoCargo
  concepto       String
  monto          Decimal      @db.Decimal(14, 2)
  moneda         Moneda       @default(ARS)
  // Si el cargo nace de un reclamo (REPARACION): 1 cargo por reclamo (idempotente).
  reclamoId      String?      @unique
  reclamo        Reclamo?     @relation(fields: [reclamoId], references: [id])
  // true → el costo se descuenta del DEPÓSITO retenido (no es deuda que el
  // inquilino paga ahora); false → deuda normal del inquilino / cargo del contrato.
  contraDeposito Boolean      @default(false)
  creadoPorId    String? // userId del usuario que lo generó
  // Cargo cobrado/saldado por la inmo → deja de ser deuda del inquilino (sale de
  // /mis-cargos y del total adeudado). null = pendiente. Sólo aplica a los que NO
  // son contraDeposito (esos se netean contra el depósito, no los paga el inquilino).
  saldadoAt      DateTime?
  saldadoPorId   String? // userId que lo marcó cobrado
  createdAt      DateTime     @default(now())

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("cargos_contrato")
}

// Ajuste del monto del alquiler (manual-asistido): el operador confirma el nuevo canon y
// desde qué período aplica. Registra el historial (antes/después) y actualiza las cuotas
// futuras impagas. Con la desregulación el índice/frecuencia varían por contrato.
model AjusteAlquiler {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato     @relation(fields: [contratoId], references: [id])
  montoAnterior  Decimal      @db.Decimal(14, 2)
  montoNuevo     Decimal      @db.Decimal(14, 2)
  periodoDesde   String // 'YYYY-MM' desde el que aplica el nuevo canon
  motivo         String? // p.ej. "ICL 12 meses (+45%)"
  creadoPorId    String?
  createdAt      DateTime     @default(now())

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("ajustes_alquiler")
}

// Renovación del contrato: extiende el plazo y (opcional) fija un nuevo canon desde un
// período. Registra el historial (fechaFin y monto anterior/nuevo). El contrato es el mismo
// (continuidad del inquilino/depósito/historial); no se crea uno nuevo.
model RenovacionContrato {
  id               String       @id @default(cuid())
  inmobiliariaId   String
  inmobiliaria     Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  contratoId       String
  contrato         Contrato     @relation(fields: [contratoId], references: [id])
  fechaFinAnterior DateTime
  fechaFinNueva    DateTime
  montoAnterior    Decimal      @db.Decimal(14, 2)
  montoNuevo       Decimal      @db.Decimal(14, 2)
  montoDesde       String // 'YYYY-MM' desde el que aplica el nuevo canon
  motivo           String?
  creadoPorId      String?
  createdAt        DateTime     @default(now())

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("renovaciones_contrato")
}

model CoInquilino {
  id             String             @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria       @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato           @relation(fields: [contratoId], references: [id])
  nombre         String
  email          String
  telefono       String?
  dni            String?
  relacion       String // texto libre: 'Pareja', 'Hermano', 'Amigo', 'Otro'
  permiso        PermisoCoInquilino
  estado         EstadoInvitacion   @default(PENDIENTE)
  invitadoAt     DateTime           @default(now())
  aceptadoAt     DateTime?

  // Una sola invitación por (contrato, email). La revocación BORRA la fila, así
  // que re-invitar tras revocar no choca. Cierra la carrera de doble-invitación.
  @@unique([contratoId, email])
  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("co_inquilinos")
}

// =============================================================================
// SCREENING
// =============================================================================

model Screening {
  id                   String          @id @default(cuid())
  inmobiliariaId       String
  inmobiliaria         Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id])
  estado               EstadoScreening @default(EN_CURSO) // pendiente→completo→convertido
  contratoId           String? // set al convertir a contrato
  contrato             Contrato?       @relation(fields: [contratoId], references: [id])
  cuit                 String
  dni                  String
  nombre               String
  apellido             String
  fechaNacimiento      DateTime
  sexo                 Sexo
  domicilio            Json
  telefonos            Json // TelefonoValidado[]: tipo CELULAR|FIJO + whatsappActivo
  email                String?
  bcra                 Json // RiesgoBcra bajo|medio|alto|irrecuperable, SituacionBcra 1-5
  cheques              Json // { rechazadosCount, rechazadosMonto, levantadosCount, levantadosMonto }
  familia              Json // VinculoFamiliar CONYUGE|PADRE_MADRE|CONVIVIENTE|HIJO|HERMANO
  rangoIngresoFamiliar RangoIngreso
  bcraFamiliar         Json
  inmuebles            Json // Inmueble.tipo DEPARTAMENTO|CASA|TERRENO
  vehiculos            Json
  ingresos             Json // IngresosArca: categoriaArca, impuestos AC|EX|NA|NI, nominaUltimos6m
  empleador            Json?
  vecinos              Json
  huellaDigital        Json // PlataformaDigital / EstadoPerfilDigital / CoherenciaHuella / hallazgos
  scoreNosis           Int // 0-1000
  recomendacion        Recomendacion
  recomendacionRazon   String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([inmobiliariaId, estado])
  @@index([contratoId])
  @@map("screenings")
}

// =============================================================================
// LIQUIDACIONES / PAGOS / COMPROBANTES
// =============================================================================

model Liquidacion {
  id                   String            @id @default(cuid())
  inmobiliariaId       String
  inmobiliaria         Inmobiliaria      @relation(fields: [inmobiliariaId], references: [id])
  contratoId           String
  contrato             Contrato          @relation(fields: [contratoId], references: [id])
  periodo              String // 'YYYY-MM'
  montoAlquiler        Decimal           @db.Decimal(14, 2)
  montoExpensas        Decimal?          @db.Decimal(14, 2)
  montoPunitorio       Decimal           @default(0) @db.Decimal(14, 2) // se recalcula al día, no congelar
  // Mora histórica CONGELADA, confirmada a mano al migrar un contrato en curso
  // ("está en la cuota 7 de 12"). Si no es null, PISA el cálculo del esquema
  // (calcularMora la respeta). Editable desde el panel.
  montoPunitorioManual Decimal?          @db.Decimal(14, 2)
  montoTotal           Decimal           @db.Decimal(14, 2)
  fechaVencimiento     DateTime
  fechaPago            DateTime?
  estado               EstadoLiquidacion @default(PENDIENTE)
  metodoPago           MetodoPago?
  moneda               Moneda            @default(ARS)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  pagos        Pago[]
  comprobantes Comprobante[]

  @@unique([contratoId, periodo])
  @@index([inmobiliariaId, estado])
  @@index([inmobiliariaId, periodo])
  @@map("liquidaciones")
}

// Pago informado por el inquilino, unificado entre apps.
// AccionConciliacion COLAPSA acá: estado + observacion + decididoPor/decididoAt
// (normaliza los typos decidiSAt/decidiSPor). N pagos por liquidación (parciales).
model Pago {
  id                  String              @id @default(cuid())
  inmobiliariaId      String
  inmobiliaria        Inmobiliaria        @relation(fields: [inmobiliariaId], references: [id])
  contratoId          String
  contrato            Contrato            @relation(fields: [contratoId], references: [id])
  liquidacionId       String
  liquidacion         Liquidacion         @relation(fields: [liquidacionId], references: [id])
  periodo             String // 'YYYY-MM'
  tipo                TipoPago            @default(TOTAL)
  monto               Decimal             @db.Decimal(14, 2)
  montoLiqTotal       Decimal?            @db.Decimal(14, 2) // snapshot del total al informar
  metodo              MetodoPagoInformado
  nroOperacion        String?
  fechaTransferencia  DateTime
  informadoAt         DateTime            @default(now()) // enviadoAt del lado inquilino
  comprobanteUrl      String? // object storage (mata dataUrl)
  comprobanteFileName String?
  comprobanteMime     String?
  comprobanteSize     Int?
  notaInquilino       String?
  extraccionIA        Json?
  estado              EstadoConciliacion  @default(INFORMADO)
  observacion         String? // obligatoria al RECHAZAR (valida API)
  decididoPorId       String?
  decididoPor         Usuario?            @relation("PagosDecididos", fields: [decididoPorId], references: [id])
  decididoAt          DateTime?
  // Autor del informe (co-inquilinos): quién de los miembros del contrato informó
  // este pago. Nullable (los cobros manuales/bancarios nacen sin autor inquilino).
  // Sirve para atribuir en notificaciones y en la lista "Pagos informados".
  informadoPorInquilinoId   String?
  informadoPorCoInquilinoId String?
  // Créditos que originaron este pago vía conciliación desde extracto bancario (0 o 1).
  creditoDetectado    CreditoDetectado?

  @@index([inmobiliariaId, estado])
  @@index([contratoId])
  @@index([liquidacionId])
  @@index([decididoPorId])
  // Hay un índice ÚNICO PARCIAL "pagos_liquidacionId_informado_key" sobre
  // (liquidacionId) WHERE estado='INFORMADO' creado a mano en la migración
  // 20260621000000_audit_unique_constraints (Prisma no expresa índices parciales).
  // Garantiza un solo pago INFORMADO por liquidación. NO lo borres si migrate dev
  // marca "drift" sobre pagos — es esperado.
  @@map("pagos")
}

// Recibo que ve el inquilino (derivable de Pago CONCILIADO, pero la app lo
// lista como recurso propio).
model Comprobante {
  id             String            @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria      @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato          @relation(fields: [contratoId], references: [id])
  liquidacionId  String?
  liquidacion    Liquidacion?      @relation(fields: [liquidacionId], references: [id])
  periodo        String // 'YYYY-MM'
  monto          Decimal           @db.Decimal(14, 2)
  moneda         Moneda            @default(ARS)
  fechaPago      DateTime
  metodo         MetodoComprobante
  pdfUrl         String

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@index([liquidacionId])
  @@map("comprobantes")
}

// =============================================================================
// EVENTOS DE CONTRATO / RENOVACIÓN
// =============================================================================

model EventoContrato {
  id             String             @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria       @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato           @relation(fields: [contratoId], references: [id])
  tipo           TipoEventoContrato
  titulo         String
  detalle        String?
  fecha          DateTime
  autor          String // 'Sistema' en eventos automáticos

  @@index([inmobiliariaId])
  @@index([contratoId, fecha])
  @@map("eventos_contrato")
}

// Unifica renovacion-storage (inquilino, typo 'decidiSAt') + mock inmo
// ('fechaIntencion') en decididoAt. SIN_RESPUESTA es valor explícito.
model IntencionRenovacion {
  id             String             @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria       @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String             @unique
  contrato       Contrato           @relation(fields: [contratoId], references: [id])
  decision       DecisionRenovacion @default(SIN_RESPUESTA)
  comentario     String?
  // Preaviso de egreso: cuándo se va el inquilino (cuando avisó que NO renueva).
  // Permite verlo venir con anticipación y planear la búsqueda de reemplazo.
  fechaEgreso    DateTime?
  decididoAt     DateTime?
  updatedAt      DateTime           @updatedAt

  @@index([inmobiliariaId])
  @@map("intenciones_renovacion")
}

// =============================================================================
// PLATA — caja, cierres, rendiciones, cargos, feed, banco
// =============================================================================

model MovimientoCaja {
  id                    String             @id @default(cuid())
  inmobiliariaId        String
  inmobiliaria          Inmobiliaria       @relation(fields: [inmobiliariaId], references: [id])
  propiedadId           String
  propiedad             Propiedad          @relation(fields: [propiedadId], references: [id])
  contratoId            String?
  contrato              Contrato?          @relation(fields: [contratoId], references: [id])
  tipo                  TipoMovimientoCaja
  categoria             CategoriaGasto
  descripcion           String
  monto                 Decimal            @db.Decimal(14, 2)
  fecha                 DateTime
  proveedor             String?
  comprobanteUrl        String?
  cargadoPor            String
  // Loop caja→rendición: al rendir se marca descontado y se linkea la rendición
  descontadoEnRendicion Boolean            @default(false)
  rendicionId           String?
  rendicion             Rendicion?         @relation(fields: [rendicionId], references: [id])
  createdAt             DateTime           @default(now())

  @@index([inmobiliariaId, fecha])
  @@index([propiedadId])
  @@index([contratoId])
  @@index([rendicionId])
  @@map("movimientos_caja")
}

// Snapshot INMUTABLE de auditoría: 1 por (tenant, fecha); re-cerrar reemplaza.
model CierreCaja {
  id              String       @id @default(cuid())
  inmobiliariaId  String
  inmobiliaria    Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  fecha           DateTime     @db.Date
  ingresos        Decimal      @db.Decimal(14, 2)
  egresos         Decimal      @db.Decimal(14, 2)
  balanceDia      Decimal      @db.Decimal(14, 2)
  efectivoEnMano  Decimal      @db.Decimal(14, 2)
  pendienteRendir Decimal      @db.Decimal(14, 2)
  movimientos     Int
  cerradoAt       DateTime
  cerradoPor      String

  @@unique([inmobiliariaId, fecha])
  @@map("cierres_caja")
}

// montoNeto = montoBruto - comisionMonto - totalGastos
model Rendicion {
  id             String          @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id])
  propietarioId  String
  propietario    Propietario     @relation(fields: [propietarioId], references: [id])
  periodo        String // 'YYYY-MM'
  montoBruto     Decimal         @db.Decimal(14, 2)
  comisionPct    Float
  comisionMonto  Decimal         @db.Decimal(14, 2) // snapshot congelado
  totalGastos    Decimal         @default(0) @db.Decimal(14, 2)
  montoNeto      Decimal         @db.Decimal(14, 2)
  rendidoAt      DateTime        @default(now())
  metodo         MetodoRendicion
  notas          String?

  gastos             GastoRendido[]
  alquileresRendidos AlquilerRendido[]
  movimientosCaja    MovimientoCaja[]

  // SIN @@unique(propietarioId, periodo): rendición INCREMENTAL — un período se
  // puede rendir varias veces a medida que entran pagos parciales. El anti-doble se
  // hace por lo YA rendido de cada liquidación (AlquilerRendido), no por período.
  @@index([inmobiliariaId, periodo])
  @@index([propietarioId, periodo])
  @@map("rendiciones")
}

// Cuánto ALQUILER (parte del propietario) se rindió de cada liquidación en cada
// rendición. Análogo a GastoRendido pero para el ingreso: permite rendir un mes en
// varias tandas (parciales) sin doble-rendir — el bruto de una rendición nueva =
// alquiler cobrado hasta ahora − lo ya rendido según estas filas.
model AlquilerRendido {
  id             String    @id @default(cuid())
  inmobiliariaId String
  rendicionId    String
  rendicion      Rendicion @relation(fields: [rendicionId], references: [id])
  liquidacionId  String
  periodo        String
  monto          Decimal   @db.Decimal(14, 2) // parte del propietario rendida en esta tanda
  participacion  Float
  propiedadId    String // snapshot, sin FK
  direccion      String // snapshot, sin FK
  createdAt      DateTime  @default(now())

  @@index([inmobiliariaId])
  @@index([rendicionId])
  @@index([liquidacionId])
  @@map("alquileres_rendidos")
}

// Snapshot congelado del gasto al rendir (el comprobante histórico sobrevive
// ediciones del origen): refId soft 'caja:<movId>' | 'reclamo:<recId>',
// propiedadId/direccion denormalizados A PROPÓSITO (sin FK dura).
model GastoRendido {
  id             String           @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria     @relation(fields: [inmobiliariaId], references: [id])
  rendicionId    String
  rendicion      Rendicion        @relation(fields: [rendicionId], references: [id])
  refId          String
  tipo           TipoGastoRendido
  fecha          DateTime
  descripcion    String
  proveedor      String?
  monto          Decimal          @db.Decimal(14, 2) // parte del propietario
  montoTotal     Decimal          @db.Decimal(14, 2)
  participacion  Float
  propiedadId    String // snapshot, sin FK
  direccion      String // snapshot, sin FK

  @@index([inmobiliariaId])
  @@index([rendicionId])
  @@map("gastos_rendidos")
}

// Marca que el cargo USO_Y_GOCE de un reclamo ya fue cobrado al inquilino.
// El monto en lote (monto=0 en el mock) lo completa el API desde costoTrabajo.
model CargoPagado {
  id             String            @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria      @relation(fields: [inmobiliariaId], references: [id])
  reclamoId      String            @unique
  reclamo        Reclamo           @relation(fields: [reclamoId], references: [id])
  contratoId     String?
  contrato       Contrato?         @relation(fields: [contratoId], references: [id])
  monto          Decimal           @db.Decimal(14, 2)
  pagadoAt       DateTime          @default(now())
  metodo         MetodoCargoPagado

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("cargos_pagados")
}

// Feed estilo banco de /pagos (app inquilino). En backend se puede componer de
// pagos+ajustes+cargos+reembolsos; se materializa para portar los seeds.
model MovimientoFeed {
  id             String          @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato        @relation(fields: [contratoId], references: [id])
  tipo           MovimientoTipo
  titulo         String
  detalle        String
  fecha          DateTime
  monto          Decimal?        @db.Decimal(14, 2) // null en info/aviso
  signo          SignoMovimiento

  @@index([inmobiliariaId])
  @@index([contratoId, fecha])
  @@map("movimientos_feed")
}

// Cuenta recaudadora que ve el inquilino en el checkout (1:1 tenant).
model DatosBancarios {
  id             String       @id @default(cuid())
  inmobiliariaId String       @unique
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  banco          String
  tipoCuenta     String
  titular        String
  cuit           String
  cbu            String
  alias          String
  updatedAt      DateTime     @updatedAt

  proximoCambio ProximoCambioBancario?

  @@map("datos_bancarios")
}

// Vigente para el banner solo si fechaDesde > hoy; al llegar la fecha, el API
// promueve cbu/alias a DatosBancarios.
model ProximoCambioBancario {
  id               String         @id @default(cuid())
  inmobiliariaId   String
  inmobiliaria     Inmobiliaria   @relation(fields: [inmobiliariaId], references: [id])
  datosBancariosId String         @unique
  datosBancarios   DatosBancarios @relation(fields: [datosBancariosId], references: [id])
  fechaDesde       DateTime
  cbu              String
  alias            String
  motivo           String?

  @@index([inmobiliariaId])
  @@map("proximos_cambios_bancarios")
}

// Upload de resumen bancario (NUNCA credenciales — constraint duro).
// MatchSugerido se calcula on-the-fly; solo persiste la decisión final en Pago.
model ResumenBancario {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  fileName       String
  fileSize       Int
  archivoUrl     String?
  subidoAt       DateTime     @default(now())
  subidoPor      String

  creditos CreditoDetectado[]

  @@index([inmobiliariaId])
  @@map("resumenes_bancarios")
}

model CreditoDetectado {
  id                String          @id @default(cuid())
  inmobiliariaId    String
  inmobiliaria      Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id])
  resumenBancarioId String
  resumenBancario   ResumenBancario @relation(fields: [resumenBancarioId], references: [id])
  fecha             DateTime
  concepto          String
  monto             Decimal         @db.Decimal(14, 2)
  titularOrigen     String
  cbuOrigen         String?
  nroOperacion      String
  bancoOrigen       String
  // Marca el crédito como ya conciliado (creó un Pago real) para no reconciliar
  // dos veces la misma línea del extracto.
  conciliado        Boolean         @default(false)
  pagoId            String?         @unique
  pago              Pago?           @relation(fields: [pagoId], references: [id])

  @@index([inmobiliariaId])
  @@index([resumenBancarioId])
  @@map("creditos_detectados")
}

enum EstadoImportacion {
  SUBIDO // archivo parseado, esperando mapeo de columnas
  MAPEADO // mapeo confirmado, esperando confirmar import
  CONFIRMADO // filas procesadas (ver `resultado`)
}

// Migración de cartera: alta masiva de propiedades/inquilinos/contratos desde un
// Excel/CSV con mapeo de columnas flexible (el admin elige qué columna es qué).
model ImportacionCartera {
  id             String            @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria      @relation(fields: [inmobiliariaId], references: [id])
  archivoUrl     String
  nombreArchivo  String
  columnas       Json // headers detectados en la hoja, en orden: string[]
  filas          Json // filas crudas parseadas (preview + datos completos): string[][]
  mapeoColumnas  Json? // { campoDestino: columnaOrigen } una vez que el admin mapea
  totalFilas     Int
  estado         EstadoImportacion @default(SUBIDO)
  resultado      Json? // { creadas: number, errores: [{ fila: number, motivo: string }] }
  creadoPor      String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([inmobiliariaId])
  @@map("importaciones_cartera")
}

// =============================================================================
// OPERACIÓN — reclamos, profesionales, visitas, consorcios, inventario
// =============================================================================

model Reclamo {
  id                String                @id @default(cuid())
  inmobiliariaId    String
  inmobiliaria      Inmobiliaria          @relation(fields: [inmobiliariaId], references: [id])
  contratoId        String
  contrato          Contrato              @relation(fields: [contratoId], references: [id])
  propiedadId       String? // para atribuir gastos en rendiciones
  propiedad         Propiedad?            @relation(fields: [propiedadId], references: [id])
  categoria         CategoriaReclamo
  descripcion       String
  urgencia          UrgenciaReclamo
  estado            EstadoReclamo         @default(ABIERTO)
  asignadoA         String? // operador interno (texto)
  fotoUrl           String?
  resolucion        String?
  clasificacion     ClasificacionReclamo? // legado (2 valores); reemplazado por `pagador`
  pagador           PagadorReclamo? // quién paga el costoTrabajo (propietario/inquilino/depósito)
  profesionalId     String? // FK reemplaza los campos denormalizados del mock
  profesional       Profesional?          @relation(fields: [profesionalId], references: [id])
  costoTrabajo      Decimal?              @db.Decimal(14, 2)
  costoTrabajoNotas String?
  createdAt         DateTime              @default(now())
  resueltoAt        DateTime?
  updatedAt         DateTime              @updatedAt

  eventos      ReclamoEvento[]
  visita       VisitaProfesional?
  confirmacion ConfirmacionReclamo?
  rating       RatingReclamo?
  cargoPagado  CargoPagado?
  cargos       CargoContrato[]

  @@index([inmobiliariaId, estado])
  @@index([contratoId])
  @@index([propiedadId])
  @@index([profesionalId])
  @@map("reclamos")
}

// Timeline del reclamo (incluye chat MENSAJE_INQUILINO/MENSAJE_INMO).
model ReclamoEvento {
  id             String            @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria      @relation(fields: [inmobiliariaId], references: [id])
  reclamoId      String
  reclamo        Reclamo           @relation(fields: [reclamoId], references: [id])
  tipo           TipoEventoReclamo
  autor          String // 'Profesional' al cerrar desde visita
  contenido      String?
  // Adjunto opcional de un mensaje (foto/archivo subido a /uploads). Habilita la
  // conversación con adjuntos entre inmobiliaria e inquilino dentro del reclamo.
  adjuntoUrl     String?
  fecha          DateTime          @default(now())

  @@index([inmobiliariaId])
  @@index([reclamoId, fecha])
  @@map("reclamo_eventos")
}

model Profesional {
  id             String               @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria         @relation(fields: [inmobiliariaId], references: [id])
  nombre         String
  categoria      CategoriaProfesional
  zona           String
  telefono       String
  email          String?
  rating         Float                @default(0) // seed; ponderado se calcula con RatingReclamo
  cantTrabajos   Int                  @default(0)
  ultimoTrabajo  DateTime?
  verificado     Boolean              @default(false)
  notas          String?
  activo         Boolean              @default(true)
  // Ecosistema: `publico` = esta inmo comparte este profesional con la red.
  // `profesionalRedId` linkea esta ficha privada a la identidad global (por teléfono)
  // sobre la que se agrega la reputación cross-tenant.
  publico          Boolean         @default(false)
  profesionalRedId String?
  profesionalRed   ProfesionalRed? @relation(fields: [profesionalRedId], references: [id])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  reclamos Reclamo[]
  visitas  VisitaProfesional[]

  @@index([inmobiliariaId])
  @@index([profesionalRedId])
  @@map("profesionales")
}

// Identidad GLOBAL del profesional en el ecosistema (sin inmobiliariaId): la misma
// persona que trabaja para varias inmobiliarias es UN solo ProfesionalRed. Clave
// natural = teléfono normalizado (solo dígitos). La reputación NO se guarda acá: se
// DERIVA on-read cruzando todos los reclamos/visitas/ratings de los Profesional
// (privados por tenant) que linkean a este id, y se expone SANITIZADA (sin PII).
model ProfesionalRed {
  id             String               @id @default(cuid())
  telefono       String               @unique // normalizado (solo dígitos) = clave de dedup
  nombre         String
  categoria      CategoriaProfesional
  zona           String               @default("")
  email          String?
  // Fase 2: sello "Garantizado/Asegurado por My Alquiler" (verificación a nivel
  // plataforma, distinto del `verificado` per-tenant). Arranca en false.
  garantizado    Boolean              @default(false)
  publicadoPorId String? // inmobiliaria que lo publicó primero (provenance, no PII pública)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  profesionales Profesional[]

  @@index([categoria])
  @@map("profesionales_red")
}

// Flujo del profesional vía link mágico /p/[token] (sin login).
// marcarListo => transacción: visita LISTO + reclamo RESUELTO + costoTrabajo.
// Los eventos VISITA_* del timeline se computan al vuelo desde acá.
model VisitaProfesional {
  id             String                  @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria            @relation(fields: [inmobiliariaId], references: [id])
  reclamoId      String                  @unique // 1 visita por reclamo
  reclamo        Reclamo                 @relation(fields: [reclamoId], references: [id])
  profesionalId  String
  profesional    Profesional             @relation(fields: [profesionalId], references: [id])
  token          String                  @unique // link mágico firmado
  fechaVisita    DateTime?
  estado         EstadoVisitaProfesional @default(ASIGNADO)
  confirmadaAt   DateTime?
  enCaminoAt     DateTime?
  listoAt        DateTime?
  notaFinal      String?
  montoCobrado   Decimal?                @db.Decimal(14, 2)
  fotoAntes      String?
  fotoDespues    String?

  @@index([inmobiliariaId])
  @@index([profesionalId])
  @@map("visitas_profesional")
}

// CONFORME ratifica el cierre; PERSISTE (comentario obligatorio) reabre/notifica.
model ConfirmacionReclamo {
  id             String            @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria      @relation(fields: [inmobiliariaId], references: [id])
  reclamoId      String            @unique
  reclamo        Reclamo           @relation(fields: [reclamoId], references: [id])
  estado         DecisionInquilino
  fecha          DateTime          @default(now())
  comentario     String?

  @@index([inmobiliariaId])
  @@map("confirmaciones_reclamo")
}

model RatingReclamo {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  reclamoId      String       @unique // 1 rating por reclamo (upsert)
  reclamo        Reclamo      @relation(fields: [reclamoId], references: [id])
  estrellas      Int // 1-5 (valida API)
  comentario     String?
  enviadoAt      DateTime     @default(now())

  @@index([inmobiliariaId])
  @@map("ratings_reclamo")
}

// =============================================================================
// CONSORCIOS
// =============================================================================

model Consorcio {
  id                    String       @id @default(cuid())
  inmobiliariaId        String
  inmobiliaria          Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  nombre                String
  direccion             String
  cantUf                Int // consistente con unidades reales (fix V2b-01)
  sociedadId            String?
  sociedad              Sociedad?    @relation(fields: [sociedadId], references: [id])
  encargado             Json? // { nombre, sueldo }
  periodoActual         String // 'YYYY-MM'
  expensasPeriodoActual Decimal      @db.Decimal(14, 2)
  desde                 DateTime
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  unidades              UnidadFuncional[]
  movimientos           MovimientoConsorcio[]
  asambleas             AsambleaConsorcio[]
  itemsInventario       ItemInventario[]
  movimientosInventario MovimientoInventario[]
  serviciosComunes      ServicioComunConsorcio[]
  propiedades           Propiedad[]

  @@index([inmobiliariaId])
  @@index([sociedadId])
  @@map("consorcios")
}

// Expensa de la UF: por coeficiente (Σ coeficientes = 100), salvo cargoFijo.
model UnidadFuncional {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  consorcioId    String
  consorcio      Consorcio    @relation(fields: [consorcioId], references: [id])
  identificacion String // '1°A', 'PB Comercial'
  titular        String
  coeficiente    Float
  telefono       String
  estado         EstadoUF     @default(AL_DIA)
  saldoDeudor    Decimal      @default(0) @db.Decimal(14, 2)
  cargoFijo      Decimal?     @db.Decimal(14, 2)
  serviciosUf    Json? // { luz?/gas?/agua?: { nis, medidor? } }

  // Backstop de la validación case-insensitive de la app: corta la carrera de
  // doble alta con la misma identificación (P2002 → 409 amigable en el endpoint).
  @@unique([consorcioId, identificacion])
  @@index([inmobiliariaId])
  @@index([consorcioId])
  @@map("unidades_funcionales")
}

// Convención de signo: monto >= 0 ingreso (cobranza UF), negativo egreso.
model MovimientoConsorcio {
  id             String                       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria                 @relation(fields: [inmobiliariaId], references: [id])
  consorcioId    String
  consorcio      Consorcio                    @relation(fields: [consorcioId], references: [id])
  fecha          DateTime
  concepto       String
  monto          Decimal                      @db.Decimal(14, 2)
  categoria      CategoriaMovimientoConsorcio

  @@index([inmobiliariaId])
  @@index([consorcioId, fecha])
  @@map("movimientos_consorcio")
}

model AsambleaConsorcio {
  id               String       @id @default(cuid())
  inmobiliariaId   String
  inmobiliaria     Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  consorcioId      String
  consorcio        Consorcio    @relation(fields: [consorcioId], references: [id])
  fecha            DateTime
  tipo             TipoAsamblea
  asunto           String
  asistentes       Int
  acuerdoPrincipal String

  @@index([inmobiliariaId])
  @@index([consorcioId])
  @@map("asambleas_consorcio")
}

// Alerta stock bajo: cantidadActual < minimoStock (derivada).
model ItemInventario {
  id             String              @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria        @relation(fields: [inmobiliariaId], references: [id])
  consorcioId    String
  consorcio      Consorcio           @relation(fields: [consorcioId], references: [id])
  categoria      CategoriaInventario
  nombre         String
  unidad         String // 'unidades', 'bidones', 'rollos'
  cantidadActual Int // clamp >= 0
  minimoStock    Int
  costoUnitario  Decimal?            @db.Decimal(14, 2)
  notas          String?
  actualizadoAt  DateTime            @updatedAt

  movimientos MovimientoInventario[]

  @@index([inmobiliariaId])
  @@index([consorcioId])
  @@map("items_inventario")
}

// ENTRADA suma, SALIDA resta, AJUSTE setea valor absoluto.
model MovimientoInventario {
  id             String                   @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria             @relation(fields: [inmobiliariaId], references: [id])
  itemId         String
  item           ItemInventario           @relation(fields: [itemId], references: [id])
  consorcioId    String
  consorcio      Consorcio                @relation(fields: [consorcioId], references: [id])
  tipo           TipoMovimientoInventario
  cantidad       Int
  motivo         String
  ufDestino      String?
  fecha          DateTime                 @default(now())
  cargadoPor     String

  @@index([inmobiliariaId])
  @@index([itemId])
  @@index([consorcioId])
  @@map("movimientos_inventario")
}

// Upsert por (consorcio, tipo).
model ServicioComunConsorcio {
  id                   String                @id @default(cuid())
  inmobiliariaId       String
  inmobiliaria         Inmobiliaria          @relation(fields: [inmobiliariaId], references: [id])
  consorcioId          String
  consorcio            Consorcio             @relation(fields: [consorcioId], references: [id])
  tipo                 TipoServicioConsorcio
  proveedor            String
  nis                  String
  numeroMedidor        String?
  costoPromedioMensual Decimal?              @db.Decimal(14, 2)
  observaciones        String?
  actualizadoAt        DateTime              @updatedAt

  @@unique([consorcioId, tipo])
  @@index([inmobiliariaId])
  @@map("servicios_comunes_consorcio")
}

// =============================================================================
// DOCUMENTOS DE CONTRATO / INQUILINOS INVITADOS
// =============================================================================

// dataUrl base64 → object storage; límite 2MB se valida server-side.
model DocumentoContrato {
  id                 String          @id @default(cuid())
  inmobiliariaId     String
  inmobiliaria       Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id])
  contratoId         String
  contrato           Contrato        @relation(fields: [contratoId], references: [id])
  tipo               TipoDocContrato
  etiqueta           String
  garanteIndex       Int?
  periodoLiquidacion String?
  nombreArchivo      String
  tipoMime           String
  tamanioBytes       Int
  archivoUrl         String
  subidoAt           DateTime        @default(now())
  subidoPor          String

  @@index([inmobiliariaId])
  @@index([contratoId])
  @@map("documentos_contrato")
}

// Invitación de inquilino (WhatsApp obligatorio, email opcional — pilotos).
// Activación: primer login OTP por email => ACTIVO + activadoAt.
model InquilinoInvitado {
  id              String                  @id @default(cuid())
  inmobiliariaId  String
  inmobiliaria    Inmobiliaria            @relation(fields: [inmobiliariaId], references: [id])
  propiedadId     String
  propiedad       Propiedad               @relation(fields: [propiedadId], references: [id])
  contratoId      String?
  contrato        Contrato?               @relation(fields: [contratoId], references: [id])
  nombre          String
  apellido        String
  telefono        String // WhatsApp obligatorio
  email           String?
  dni             String
  fechaNacimiento DateTime?
  estado          EstadoInvitadoInquilino @default(PENDIENTE_ACTIVACION)
  invitadoAt      DateTime                @default(now())
  invitadoPor     String                  @default("Equipo de la inmobiliaria")
  activadoAt      DateTime?

  coInquilinos CoInquilinoInvitado[]
  documentos   DocumentoAdjuntoInvitado[]

  @@index([inmobiliariaId])
  @@index([propiedadId])
  @@index([contratoId])
  @@map("inquilinos_invitados")
}

model CoInquilinoInvitado {
  id             String             @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria       @relation(fields: [inmobiliariaId], references: [id])
  invitadoId     String
  invitado       InquilinoInvitado  @relation(fields: [invitadoId], references: [id])
  nombre         String
  apellido       String
  celular        String
  email          String?
  relacion       String // texto libre
  permiso        PermisoCoInquilino

  @@index([inmobiliariaId])
  @@index([invitadoId])
  @@map("co_inquilinos_invitados")
}

model DocumentoAdjuntoInvitado {
  id             String            @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria      @relation(fields: [inmobiliariaId], references: [id])
  invitadoId     String
  invitado       InquilinoInvitado @relation(fields: [invitadoId], references: [id])
  nombre         String
  tipoMime       String
  tamanioBytes   Int
  archivoUrl     String
  subidoAt       DateTime          @default(now())

  @@index([inmobiliariaId])
  @@index([invitadoId])
  @@map("documentos_adjuntos_invitado")
}

// =============================================================================
// COMUNICACIÓN — anuncios, boletas, servicios, chat, documentos, certificado
// =============================================================================

// destinatariosCount se materializa al enviar (snapshot de la audiencia).
model Anuncio {
  id                 String           @id @default(cuid())
  inmobiliariaId     String
  inmobiliaria       Inmobiliaria     @relation(fields: [inmobiliariaId], references: [id])
  titulo             String
  cuerpo             String
  prioridad          PrioridadAnuncio @default(NORMAL)
  audiencia          AudienciaAnuncio
  audienciaIds       String[] // cnsr_* (INQUILINOS_CONSORCIO) o cnt_* (CONTRATOS_ESPECIFICOS)
  canales            CanalAnuncio[]
  enviadoPor         String
  enviadoAt          DateTime
  destinatariosCount Int              @default(0)
  programadoPara     DateTime?

  acuses AnuncioAcuse[]

  @@index([inmobiliariaId, enviadoAt])
  @@map("anuncios")
}

// unique(anuncioId, usuarioId) del requerimiento: el "usuario" lector es el
// Inquilino logueado (la identidad sale del JWT, muere DEMO_INQUILINO).
model AnuncioAcuse {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  anuncioId      String
  anuncio        Anuncio      @relation(fields: [anuncioId], references: [id])
  inquilinoId    String
  inquilino      Inquilino    @relation(fields: [inquilinoId], references: [id])
  leidoAt        DateTime? // marcarLeido no pisa leidoAt previo
  confirmadoAt   DateTime? // 'Enterado' implica leidoAt si faltaba

  @@unique([anuncioId, inquilinoId])
  @@index([inmobiliariaId])
  @@index([inquilinoId])
  @@map("anuncios_acuses")
}

model BoletaServicio {
  id             String       @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato     @relation(fields: [contratoId], references: [id])
  tipo           TipoServicio
  periodo        String // 'YYYY-MM'
  monto          Decimal      @db.Decimal(14, 2)
  vencimiento    DateTime
  estado         EstadoBoleta @default(SUBIDA) // label UI de SUBIDA: 'Cargada'
  nombreArchivo  String
  tipoMime       String
  tamanioBytes   Int
  archivoUrl     String
  subidoAt       DateTime     @default(now())
  pagadoAt       DateTime?
  notas          String?

  @@index([inmobiliariaId])
  @@index([contratoId, periodo])
  @@map("boletas_servicio")
}

// Upsert por (propiedad, tipo).
model ServicioPublico {
  id                     String       @id @default(cuid())
  inmobiliariaId         String
  inmobiliaria           Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  propiedadId            String
  propiedad              Propiedad    @relation(fields: [propiedadId], references: [id])
  tipo                   TipoServicio
  distribuidora          String
  nis                    String
  numeroMedidor          String?
  titular                String?
  observaciones          String?
  consumoPromedioMensual Decimal?     @db.Decimal(14, 2)
  actualizadoAt          DateTime     @updatedAt

  @@unique([propiedadId, tipo])
  @@index([inmobiliariaId])
  @@map("servicios_publicos")
}

// Asistente IA del contrato; citas = [{ clausula, texto }].
model ChatMensaje {
  id             String         @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria   @relation(fields: [inmobiliariaId], references: [id])
  contratoId     String
  contrato       Contrato       @relation(fields: [contratoId], references: [id])
  rol            RolMensajeChat
  contenido      String
  citas          Json?
  createdAt      DateTime       @default(now())

  @@index([inmobiliariaId])
  @@index([contratoId, createdAt])
  @@map("chat_mensajes")
}

// Checklist documental configurable por inmobiliaria (antes constante).
model SlotDocumento {
  id             String             @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria       @relation(fields: [inmobiliariaId], references: [id])
  codigo         String // 'dni-frente', 'recibo-1', ...
  categoria      CategoriaDocumento
  titulo         String
  descripcion    String
  requerido      Boolean            @default(false)

  documentos Documento[]

  @@unique([inmobiliariaId, codigo])
  @@map("slots_documento")
}

model Documento {
  id             String             @id @default(cuid())
  inmobiliariaId String
  inmobiliaria   Inmobiliaria       @relation(fields: [inmobiliariaId], references: [id])
  inquilinoId    String
  inquilino      Inquilino          @relation(fields: [inquilinoId], references: [id])
  categoria      CategoriaDocumento
  nombre         String
  tipoMime       String
  tamanioBytes   Int
  archivoUrl     String
  subidoAt       DateTime           @default(now())
  vencimiento    DateTime?
  slotId         String? // sin slot = documento libre en OTRO
  slot           SlotDocumento?     @relation(fields: [slotId], references: [id])

  @@index([inmobiliariaId])
  @@index([inquilinoId])
  @@index([slotId])
  @@map("documentos")
}

// 'Reemplazo del garante': hash HMAC-SHA256 firmado con clave privada de
// My Alquiler sobre SOLO datos inmutables (dni|contratoId|inmobiliaria).
// Verificación pública /verificar/[hash]: firma + no-revocación. Validez 30 días.
model CertificadoInquilino {
  id              String         @id @default(cuid())
  inmobiliariaId  String
  inmobiliaria    Inmobiliaria   @relation(fields: [inmobiliariaId], references: [id])
  hash            String         @unique // formato XXXX-XXXX-XXXX
  inquilinoId     String
  inquilino       Inquilino      @relation(fields: [inquilinoId], references: [id])
  contratoId      String
  contrato        Contrato       @relation(fields: [contratoId], references: [id])
  inquilinoData   Json // snapshot { nombre, dni, email, telefono }
  contratoActual  Json // snapshot { direccion, inmobiliaria, fechaInicio, montoMensual, moneda, mesesCumplidos }
  historial       Json // snapshot { cuotasTotales, cuotasPagadas, cuotasAlDia, atrasoPromedioDias, pagosRechazados, ratingPromedio }
  nivel           NivelHistorial
  nivelDetalle    String
  generadoAt      DateTime       @default(now())
  validoHasta     DateTime
  urlVerificacion String
  revocadoAt      DateTime?

  @@index([inmobiliariaId])
  @@index([inquilinoId])
  @@index([contratoId])
  @@map("certificados_inquilino")
}
